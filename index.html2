<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartFridge - Haltbarkeitsmanager</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <style>
        :root {
            --status-green: #22c55e;
            --status-yellow: #eab308;
            --status-red: #ef4444;
            --status-dark-red: #7f1d1d;
        }
        .status-gruen { background-color: var(--status-green); color: white; }
        .status-gelb { background-color: var(--status-yellow); color: black; }
        .status-rot { background-color: var(--status-red); color: white; }
        .status-weinrot { background-color: var(--status-dark-red); color: white; }
    </style>
</head>
<body class="bg-slate-50 font-sans pb-24">

    <header class="bg-blue-600 text-white p-4 text-center shadow-lg sticky top-0 z-20">
        <h1 class="text-xl font-bold flex justify-center items-center gap-2">
            <i data-lucide="refrigerator"></i> SmartFridge
        </h1>
    </header>

    <main class="max-w-md mx-auto p-4">
        <section id="page-fridge" class="page-section space-y-4">
            <h2 class="text-lg font-semibold text-gray-700">Mein Kühlschrank</h2>
            <div id="fridge-empty" class="hidden text-center py-12 text-gray-400">
                <i data-lucide="salad" class="mx-auto w-16 h-16 mb-2"></i>
                <p>Dein Kühlschrank ist leer.<br>Scanne Produkte, um sie hinzuzufügen.</p>
            </div>
            <div id="food-list" class="space-y-3"></div>
        </section>

        <section id="page-scan" class="page-section hidden space-y-4">
            <h2 class="text-lg font-semibold text-gray-700">Produkt scannen</h2>
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-200">
                <div id="reader" class="w-full rounded-lg overflow-hidden"></div>
                <button onclick="simulateScan()" class="w-full mt-4 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-3 rounded-xl transition">
                    Barcode simulieren (Demo)
                </button>
            </div>
        </section>

        <section id="page-recipes" class="page-section hidden space-y-4">
            <h2 class="text-lg font-semibold text-gray-700">Ideen für deine Reste</h2>
            <div id="recipe-list" class="space-y-3"></div>
        </section>
    </main>

    <nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 px-6 py-3 flex justify-between z-30">
        <button onclick="switchPage('fridge')" class="nav-btn text-blue-600" data-page="fridge"><i data-lucide="refrigerator"></i><span class="text-[10px] block">Kühlschrank</span></button>
        <button onclick="switchPage('scan')" class="nav-btn text-gray-400" data-page="scan"><i data-lucide="scan-barcode"></i><span class="text-[10px] block">Scannen</span></button>
        <button onclick="switchPage('recipes')" class="nav-btn text-gray-400" data-page="recipes"><i data-lucide="chef-hat"></i><span class="text-[10px] block">Rezepte</span></button>
    </nav>

    <script>
        let inventory = JSON.parse(localStorage.getItem('fridge_inventory')) || [];
        let html5QrcodeScanner = null;

        const getStatusClass = (days) => {
            if (days >= 9) return 'status-gruen';
            if (days >= 4) return 'status-gelb';
            if (days >= 2) return 'status-rot';
            return 'status-weinrot';
        };

        function renderFridge() {
            const listContainer = document.getElementById('food-list');
            const emptyState = document.getElementById('fridge-empty');
            
            listContainer.innerHTML = '';
            
            if (inventory.length === 0) {
                emptyState.classList.remove('hidden');
            } else {
                emptyState.classList.add('hidden');
                inventory.sort((a, b) => a.daysLeft - b.daysLeft).forEach(item => {
                    const card = document.createElement('div');
                    card.className = `p-4 rounded-xl shadow-sm flex justify-between items-center ${getStatusClass(item.daysLeft)}`;
                    card.innerHTML = `
                        <div>
                            <h3 class="font-bold">${item.name}</h3>
                            <p class="text-xs opacity-80">${item.daysLeft} Tage haltbar</p>
                        </div>
                        <button onclick="deleteItem(${item.id})" class="p-2 hover:bg-black/10 rounded-full transition"><i data-lucide="trash-2" class="w-5 h-5"></i></button>
                    `;
                    listContainer.appendChild(card);
                });
            }
            lucide.createIcons();
            updateRecipes();
        }

        function switchPage(pageId) {
            document.querySelectorAll('.page-section').forEach(s => s.classList.add('hidden'));
            document.getElementById(`page-${pageId}`).classList.remove('hidden');
            
            document.querySelectorAll('.nav-btn').forEach(b => {
                b.classList.toggle('text-blue-600', b.dataset.page === pageId);
                b.classList.toggle('text-gray-400', b.dataset.page !== pageId);
            });

            pageId === 'scan' ? startScanner() : stopScanner();
        }

        function startScanner() {
            if (!html5QrcodeScanner) {
                html5QrcodeScanner = new Html5QrcodeScanner("reader", { fps: 10, qrbox: 200 });
                html5QrcodeScanner.render((txt) => { onScanSuccess(txt); });
            }
        }

        function stopScanner() {
            if (html5QrcodeScanner) {
                html5QrcodeScanner.clear().then(() => html5QrcodeScanner = null);
            }
        }

        function onScanSuccess(decodedText) {
            const items = ["Milch", "Pasta", "Joghurt", "Salat", "Hähnchen"];
            addProduct(items[Math.floor(Math.random() * items.length)], Math.floor(Math.random() * 10) + 1);
            switchPage('fridge');
        }

        function addProduct(name, days) {
            inventory.push({ id: Date.now(), name, daysLeft: days });
            localStorage.setItem('fridge_inventory', JSON.stringify(inventory));
            renderFridge();
        }

        function deleteItem(id) {
            inventory = inventory.filter(i => i.id !== id);
            localStorage.setItem('fridge_inventory', JSON.stringify(inventory));
            renderFridge();
        }

        window.onload = () => { renderFridge(); };
    </script>
</body>
</html>
